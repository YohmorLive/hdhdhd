# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/lebalert

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=30d

# Firebase (path to service account key JSON)
FIREBASE_SERVICE_ACCOUNT=./config/serviceAccountKey.json

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_IDS=-1001234567890,-1009876543210

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ReliefWeb API
RELIEFWEB_API_URL=https://api.reliefweb.int/v1
